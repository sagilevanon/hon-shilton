{
  "name": "hon-shilton-pipeline",
  "version": "0.1.0",
  "description": "Local scrape + Claude Code extraction pipeline for Hon Shilton. Writes the SQLite graph DB that the display backend reads.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "ingest": "NODE_NO_WARNINGS=1 tsx src/ingest.ts",
    "ingest-feed": "NODE_NO_WARNINGS=1 tsx src/ingest-feed.ts",
    "debug-ingest": "NODE_NO_WARNINGS=1 GRAPH_DEBUG_TIMING=1 tsx src/debug-ingest.ts",
    "debug-verify": "NODE_NO_WARNINGS=1 GRAPH_DEBUG_TIMING=1 tsx src/debug-verify.ts",
    "verify": "NODE_NO_WARNINGS=1 tsx src/verify-edges.ts",
    "re-extract": "NODE_NO_WARNINGS=1 tsx src/re-extract.ts",
    "debug-diff": "NODE_NO_WARNINGS=1 tsx src/debug-diff.ts",
    "bench": "NODE_NO_WARNINGS=1 tsx src/bench.ts",
    "dump": "NODE_NO_WARNINGS=1 tsx src/dump.ts",
    "build": "tsc",
    "test": "NODE_NO_WARNINGS=1 node --import tsx --test 'src/**/*.test.ts'"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2"
  }
}
